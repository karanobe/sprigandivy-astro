---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ===================== HERO ===================== -->
  <section id="hero" class="hero">
    <div class="hero-bg">
      <img
        src="/images/portfolio/styled-shoot/4.JPG"
        alt="Elegant wedding event by Sprig & Ivy"
        class="hero-img"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="eyebrow">Wedding &amp; Event Planners</span>
      <span class="gold-line"></span>
      <h1>To Know Us Is<br />to Love Us</h1>
      <p>We would love to meet up and chat about how we can make YOUR event happen!</p>
      <a href="#contact" class="btn btn-outline">Let's Chat</a>
    </div>
    <a href="#about" class="hero-scroll" aria-label="Scroll down">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </a>
  </section>

  <!-- ===================== MARQUEE ===================== -->
  <div class="marquee-strip">
    <div class="marquee-track">
      <span>Weddings</span><span class="dot">&#8226;</span>
      <span>Birthdays</span><span class="dot">&#8226;</span>
      <span>Baby Showers</span><span class="dot">&#8226;</span>
      <span>Retirement Parties</span><span class="dot">&#8226;</span>
      <span>Styled Shoots</span><span class="dot">&#8226;</span>
      <span>Day-of Coordination</span><span class="dot">&#8226;</span>
      <span>Event Rentals</span><span class="dot">&#8226;</span>
      <span>Weddings</span><span class="dot">&#8226;</span>
      <span>Birthdays</span><span class="dot">&#8226;</span>
      <span>Baby Showers</span><span class="dot">&#8226;</span>
      <span>Retirement Parties</span><span class="dot">&#8226;</span>
      <span>Styled Shoots</span><span class="dot">&#8226;</span>
      <span>Day-of Coordination</span><span class="dot">&#8226;</span>
      <span>Event Rentals</span><span class="dot">&#8226;</span>
    </div>
  </div>

  <!-- ===================== ABOUT ===================== -->
  <section id="about" class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-images">
          <div class="about-img-main">
            <img
              src="/images/about-us.jpg"
              alt="Shraddha & Karan — Sprig & Ivy founders"
              loading="lazy"
              width="500"
              height="600"
            />
          </div>
          <div class="about-img-accent">
            <img
              src="/images/portfolio/Lauren-Nick/11.JPG"
              alt="Beautiful wedding decor by Sprig & Ivy"
              loading="lazy"
              width="280"
              height="360"
            />
          </div>
        </div>
        <div class="about-content">
          <span class="eyebrow">Our Story</span>
          <span class="gold-line gold-line-left"></span>
          <h2>Your Personal<br />Dream Maker</h2>
          <blockquote>
            "To create something exceptional, your mindset must be relentlessly focused on the smallest detail!"
          </blockquote>
          <p>
            From birthday gatherings and baby showers to retirement parties and weddings, no event is too big or too small for Sprig &amp; Ivy! We specialize in providing the highest level of customer service and ensuring each event is true to our client's vision.
          </p>
          <p>
            Sprig &amp; Ivy is a team with a keen eye in organization and unique design. We've done the research and taken the time to perfect our craft — a number of the services we provide are created in-house, without involving any other vendors.
          </p>
          <p>Sprig &amp; Ivy is truly a one-stop shop for all your event planning needs.</p>
          <div class="about-sig">— Shraddha &amp; Karan</div>
          <a href="#contact" class="btn btn-outline-gold" style="margin-top:2rem">Work With Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section id="services" class="section services">
    <div class="services-bg-stripe"></div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">What We Do</span>
        <span class="gold-line"></span>
        <h2>Sit Back While We Create<br />the Experience of a Lifetime</h2>
      </div>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Full-Service Wedding Planning</h3>
          <p>From venue selection to vendor management, we handle every detail of your perfect day so you can be fully present in each precious moment.</p>
          <a href="#contact" class="service-link">Inquire Now &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <h3>Day-of Coordination</h3>
          <p>You've planned it beautifully — we'll make sure it unfolds flawlessly. Our day-of coordination ensures a seamless, stress-free celebration.</p>
          <a href="#contact" class="service-link">Inquire Now &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>Event Design &amp; Styling</h3>
          <p>We create curated, cohesive aesthetics for any event — birthdays, showers, retirement parties — infused with your personal touch and our creative vision.</p>
          <a href="#contact" class="service-link">Inquire Now &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Event Rentals</h3>
          <p>Browse our curated selection of elegant rentals — arches, linens, charger plates, and more — to elevate your event without the overhead.</p>
          <a href="#contact" class="service-link">Inquire Now &rarr;</a>
        </div>
        <div class="service-card">
          <div class="service-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Corporate &amp; Social Events</h3>
          <p>Whether it's an intimate gathering or a corporate celebration, we bring the same precision and passion to every event we touch.</p>
          <a href="#contact" class="service-link">Inquire Now &rarr;</a>
        </div>
        <div class="service-card service-card-cta">
          <p class="service-cta-label">Ready to start?</p>
          <h3>Let's Bring Your Vision to Life</h3>
          <a href="#contact" class="btn btn-gold">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="gallery-strip" aria-label="Portfolio gallery">
    <div class="gallery-grid">
      <div class="gallery-item gallery-item-tall">
        <img src="/images/portfolio/styled-shoot/4.JPG" alt="Styled shoot by Sprig & Ivy" loading="lazy" />
        <div class="gallery-overlay">
          <a href="#contact" class="btn btn-outline">Book This Look</a>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/Lauren-Nick/16.JPG" alt="Wedding by Sprig & Ivy" loading="lazy" />
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/Cecilia-80th/5.JPG" alt="80th birthday event by Sprig & Ivy" loading="lazy" />
      </div>
      <div class="gallery-item gallery-item-wide">
        <img src="/images/portfolio/Dana-Shane/1.JPG" alt="Wedding reception by Sprig & Ivy" loading="lazy" />
        <div class="gallery-overlay">
          <a href="#contact" class="btn btn-outline">Plan Your Event</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section id="testimonials" class="section testimonials">
    <div class="testimonials-bg">
      <img src="/images/banner/clients.jpg" alt="" aria-hidden="true" loading="lazy" />
      <div class="testimonials-overlay"></div>
    </div>
    <div class="container">
      <div class="section-header" style="color:white">
        <span class="eyebrow" style="color:var(--gold-light)">Client Love</span>
        <span class="gold-line"></span>
        <h2 style="color:white">What Our Clients Say</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <img src="/images/05.jpg" alt="Randy M." loading="lazy" />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"They went above and beyond in working with my schedule. We did an old Hollywood theme and had my entire house and yard setup for her arrival. My wife had a good time. Thank you."</p>
          <div class="testimonial-author">
            <strong>Randy M.</strong>
            <span>Irvine, 2020 — 50th Birthday Party</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <img src="/images/06.jpg" alt="Kimberly S." loading="lazy" />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"They walked me through every step. My favorite part was the wedding budget they helped me and my fiancé create and also cute DIY ideas that would help save more money. I would definitely recommend them."</p>
          <div class="testimonial-author">
            <strong>Kimberly S.</strong>
            <span>Lake Forest, 2021 — Wedding Planning</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <img src="/images/07.jpg" alt="Amber S." loading="lazy" />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"AMAZING! I had a smaller wedding and other coordinators were charging in the thousands and it just seemed totally ridiculous. I came across Sprig &amp; Ivy and literally felt like these girls were my BFF!"</p>
          <div class="testimonial-author">
            <strong>Amber S.</strong>
            <span>San Diego, 2021 — Wedding Coordination</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <img src="/images/08.jpg" alt="Dhara P." loading="lazy" />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"I price shopped like crazy and no other coordinator offered the price they were able to give me. They were so willing to work with my budget and didn't force any additional services. I will work with them again."</p>
          <div class="testimonial-author">
            <strong>Dhara P.</strong>
            <span>Chino Hills, 2021 — Event Coordination</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="cta-band section-sm">
    <div class="container">
      <div class="cta-band-inner">
        <div>
          <span class="eyebrow">Ready to Begin?</span>
          <h2>Let's Make Your Event Unforgettable</h2>
        </div>
        <a href="#contact" class="btn btn-gold">Start Planning</a>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT ===================== -->
  <section id="contact" class="section contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="eyebrow">Get In Touch</span>
          <span class="gold-line gold-line-left"></span>
          <h2>Let's Chat About<br />Your Event</h2>
          <p>Whether you're just beginning to dream or ready to start planning, we'd love to connect. Fill out the form and we'll be in touch shortly!</p>
          <div class="contact-details">
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 5.27 5.27l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
              </div>
              <div>
                <span>Phone</span>
                <a href="tel:+17144559150">+1.714.455.9150</a>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <span>Email</span>
                <a href="mailto:contact@sprigandivy.com">contact@sprigandivy.com</a>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <span>Location</span>
                <p>Placentia, CA &amp; surrounding areas</p>
              </div>
            </div>
          </div>
          <div class="contact-social">
            <a href="https://www.instagram.com/sprigandivy" target="_blank" rel="noopener">@sprigandivy</a>
          </div>
        </div>

        <div class="contact-form-wrap">
          <form
            id="contact-form"
            action="https://submit-form.com/lDeONWre"
            method="POST"
            novalidate
          >
            <!-- Honeypot -->
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <!-- Redirect after submit -->
            <input type="hidden" name="_redirect" value="https://sprigandivy.com/?sent=1" />

            <div class="form-row">
              <div class="form-group">
                <label for="first_name">First Name <span aria-hidden="true">*</span></label>
                <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="last_name">Last Name <span aria-hidden="true">*</span></label>
                <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address <span aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="event_type">Type of Event</label>
                <select id="event_type" name="event_type">
                  <option value="" disabled selected>Select event type</option>
                  <option>Wedding</option>
                  <option>Birthday Party</option>
                  <option>Baby Shower</option>
                  <option>Retirement Party</option>
                  <option>Corporate Event</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label for="event_date">Date of Event</label>
                <input type="date" id="event_date" name="event_date" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="location">Location of Event</label>
                <input type="text" id="location" name="location" placeholder="City, Venue name..." />
              </div>
              <div class="form-group">
                <label for="guests">Number of Guests</label>
                <input type="number" id="guests" name="guests" min="1" placeholder="Estimated guest count" />
              </div>
            </div>
            <div class="form-group">
              <label for="message">Tell Us About Your Event</label>
              <textarea id="message" name="message" rows="5" placeholder="Share your vision, inspiration, budget range, or anything else you'd like us to know..."></textarea>
            </div>
            <button type="submit" class="btn btn-gold form-submit">Send My Inquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.5) 50%,
      rgba(0,0,0,0.6) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 0 2rem;
    max-width: 700px;
  }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  .hero-content p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255,255,255,0.6);
    animation: bounce 2s infinite;
    transition: color 0.2s;
  }

  .hero-scroll:hover { color: white; }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== MARQUEE ===== */
  .marquee-strip {
    overflow: hidden;
    background: var(--cream);
    border-top: 1px solid var(--light-gray);
    border-bottom: 1px solid var(--light-gray);
    padding: 1.2rem 0;
  }

  .marquee-track {
    display: flex;
    gap: 2rem;
    white-space: nowrap;
    animation: marquee 30s linear infinite;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 500;
  }

  .marquee-track .dot { color: var(--gold); }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== ABOUT ===== */
  .about { background: var(--white); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-images {
    position: relative;
  }

  .about-img-main {
    position: relative;
    z-index: 2;
  }

  .about-img-main img {
    width: 100%;
    height: 580px;
    object-fit: cover;
    object-position: top;
  }

  .about-img-accent {
    position: absolute;
    bottom: -40px;
    right: -40px;
    z-index: 3;
    border: 6px solid var(--white);
    box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  }

  .about-img-accent img {
    width: 220px;
    height: 280px;
    object-fit: cover;
  }

  .about-content h2 {
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    margin-bottom: 1.5rem;
  }

  .about-content blockquote {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    color: var(--gold-dark);
    border-left: 2px solid var(--gold);
    padding-left: 1.5rem;
    margin: 1.5rem 0 2rem;
    line-height: 1.6;
  }

  .about-content p {
    font-size: 0.95rem;
    color: var(--gray);
    margin-bottom: 1rem;
  }

  .about-sig {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--gold-dark);
    margin-top: 1.5rem;
  }

  /* ===== SERVICES ===== */
  .services {
    background: var(--off-white);
    position: relative;
    overflow: hidden;
  }

  .services-bg-stripe {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--gold);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-header h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    margin-top: 0.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    background: var(--white);
    padding: 2.5rem 2rem;
    border: 1px solid var(--light-gray);
    transition: all 0.3s ease;
  }

  .service-card:hover {
    border-color: var(--gold-light);
    box-shadow: 0 8px 40px rgba(201,169,110,0.12);
    transform: translateY(-4px);
  }

  .service-icon {
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .service-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
  }

  .service-card p {
    font-size: 0.88rem;
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .service-link {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    transition: color 0.2s;
  }

  .service-link:hover { color: var(--gold-dark); }

  .service-card-cta {
    background: var(--charcoal);
    border-color: var(--charcoal);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 1rem;
  }

  .service-card-cta:hover {
    border-color: var(--charcoal);
    transform: translateY(-4px);
  }

  .service-cta-label {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold) !important;
