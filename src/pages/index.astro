---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import heroImg        from '../assets/images/portfolio/styled-shoot/4.JPG';
import aboutImg       from '../assets/images/about-us.jpg';
import gallery2Img    from '../assets/images/portfolio/Lauren-Nick/16.JPG';
import gallery3Img    from '../assets/images/portfolio/Cecilia-80th/5.JPG';
import gallery4Img    from '../assets/images/portfolio/Dana-Shane/1.JPG';
import clientsBgImg   from '../assets/images/banner/clients.jpg';
import avatar05       from '../assets/images/05.jpg';
import avatar06       from '../assets/images/06.jpg';
import avatar07       from '../assets/images/07.jpg';
import avatar08       from '../assets/images/08.jpg';
---

<Layout>
  <!-- ===================== HERO ===================== -->
  <section id="hero" class="hero">
    <div class="hero-bg">
      <Image
        src={heroImg}
        alt="Elegant wedding event by Sprig & Ivy"
        class="hero-img"
        loading="eager"
        fetchpriority="high"
        widths={[768, 1280, 1920]}
        sizes="100vw"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <span class="eyebrow">Wedding &amp; Event Planners · Orange County, CA</span>
      <span class="gold-line"></span>
      <h1>Every Detail,<br />Beautifully Executed</h1>
      <p>From intimate gatherings to grand celebrations — we plan, design, and coordinate events that feel effortlessly you.</p>
      <a href="#contact" class="btn btn-outline">Start Planning</a>
    </div>
    <a href="#about" class="hero-scroll" aria-label="Scroll down">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </a>
  </section>

  <!-- ===================== MARQUEE ===================== -->
  <div class="marquee-strip">
    <div class="marquee-track">
      <span>Weddings</span><span class="dot">&#8226;</span>
      <span>Birthdays</span><span class="dot">&#8226;</span>
      <span>Baby Showers</span><span class="dot">&#8226;</span>
      <span>Retirement Parties</span><span class="dot">&#8226;</span>
      <span>Styled Shoots</span><span class="dot">&#8226;</span>
      <span>Day-of Coordination</span><span class="dot">&#8226;</span>
      <span>Event Rentals</span><span class="dot">&#8226;</span>
      <span>Weddings</span><span class="dot">&#8226;</span>
      <span>Birthdays</span><span class="dot">&#8226;</span>
      <span>Baby Showers</span><span class="dot">&#8226;</span>
      <span>Retirement Parties</span><span class="dot">&#8226;</span>
      <span>Styled Shoots</span><span class="dot">&#8226;</span>
      <span>Day-of Coordination</span><span class="dot">&#8226;</span>
      <span>Event Rentals</span><span class="dot">&#8226;</span>
    </div>
  </div>

  <!-- ===================== ABOUT ===================== -->
  <section id="about" class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-images">
          <div class="about-img-main">
            <Image
              src={aboutImg}
              alt="Shraddha Sharma — Sprig & Ivy founder"
              loading="lazy"
              widths={[500, 900]}
              sizes="(max-width: 900px) 100vw, 50vw"
            />
          </div>
        </div>
        <div class="about-content">
          <span class="eyebrow">Our Story</span>
          <span class="gold-line gold-line-left"></span>
          <h2>Your Personal<br />Dream Maker</h2>
          <blockquote>
            "To create something exceptional, your mindset must be relentlessly focused on the smallest detail!"
          </blockquote>
          <p>
            From birthday gatherings and baby showers to retirement parties and weddings, no event is too big or too small for Sprig &amp; Ivy! We specialize in providing the highest level of customer service and ensuring each event is true to our client's vision.
          </p>
          <p>
            Sprig &amp; Ivy is a team with a keen eye in organization and unique design. We've done the research and taken the time to perfect our craft — a number of the services we provide are created in-house, without involving any other vendors.
          </p>
          <p>Sprig &amp; Ivy is truly a one-stop shop for all your event planning needs.</p>
          <div class="about-sig">— Shraddha Sharma</div>
          <a href="#contact" class="btn btn-outline-gold" style="margin-top:2rem">Work With Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== SERVICES ===================== -->
  <section id="services" class="section services">
    <div class="services-bg-stripe"></div>
    <div class="container">

      <!-- Wedding Packages -->
      <div class="section-header">
        <span class="eyebrow">Wedding Services</span>
        <span class="gold-line"></span>
        <h2>Sit Back While We Create<br />the Experience of a Lifetime</h2>
      </div>

      <div class="packages-grid">

        <!-- Sprig of Holly -->
        <div class="package-card">
          <div class="package-header">
            <span class="package-eyebrow">Entry</span>
            <h3>Sprig of Holly</h3>
            <p class="package-type">Day of Coordination</p>
          </div>
          <p class="package-desc">Ideal for couples who have done the leg work in planning their big day, but would like assistance in execution on the day of their wedding.</p>
          <ul class="package-list">
            <li>3 face-to-face meetings (1 must be at venue)</li>
            <li>Creation of wedding timeline</li>
            <li>Manage all vendor details</li>
            <li>Assistance with budget &amp; breakdown of costs</li>
            <li>Organize wedding party &amp; conduct rehearsal</li>
            <li>Assist wedding party with flowers/corsages</li>
            <li>Seating arrangement &amp; crowd control</li>
            <li>Set up personal items (signage, DIY décor, etc.)</li>
            <li>Audio/visual check</li>
            <li>Cue ceremony &amp; reception events</li>
            <li>Breakdown &amp; collection of personal items</li>
            <li>Distribute final vendor payments (provided by client)</li>
            <li>Unlimited phone &amp; email contact</li>
          </ul>
          <a href="#contact" class="btn btn-outline-gold package-cta">Inquire Now</a>
        </div>

        <!-- Buttercup Ivy -->
        <div class="package-card package-card-featured">
          <div class="package-badge">Most Popular</div>
          <div class="package-header">
            <span class="package-eyebrow">Enhanced</span>
            <h3>Buttercup Ivy</h3>
            <p class="package-type">Partial Wedding Planning</p>
          </div>
          <p class="package-desc">Designed for couples needing professional guidance in the essential aspects of wedding planning. Includes everything in Sprig of Holly.</p>
          <ul class="package-list">
            <li>5 face-to-face meetings (1 must be at venue)</li>
            <li>Budget creation &amp; vendor sourcing</li>
            <li>Guidance with theme, décor, colors &amp; invitations</li>
            <li>Keep client on track with planning process</li>
            <li>Assist with review of all vendor contracts</li>
            <li>Creation of wedding timeline</li>
            <li>Manage all vendor details</li>
            <li>Organize wedding party &amp; conduct rehearsal</li>
            <li>Assist wedding party with flowers/corsages</li>
            <li>Seating arrangement &amp; crowd control</li>
            <li>Set up personal items (signage, DIY décor, etc.)</li>
            <li>Audio/visual check</li>
            <li>Cue ceremony &amp; reception events</li>
            <li>Breakdown &amp; collection of personal items</li>
            <li>Distribute final vendor payments (provided by client)</li>
            <li>Unlimited phone &amp; email contact</li>
          </ul>
          <a href="#contact" class="btn btn-gold package-cta">Inquire Now</a>
        </div>

        <!-- Mona Lisa Ivy -->
        <div class="package-card">
          <div class="package-header">
            <span class="package-eyebrow">Full Service</span>
            <h3>Mona Lisa Ivy</h3>
            <p class="package-type">Full Wedding Planning</p>
          </div>
          <p class="package-desc">Personalized assistance from beginning to end for all aspects of your wedding. Includes everything in Buttercup Ivy and Sprig of Holly.</p>
          <ul class="package-list">
            <li>8 face-to-face meetings (1 must be at venue)</li>
            <li>Venue selection &amp; site visit setup</li>
            <li>Vendor sourcing &amp; quote negotiation</li>
            <li>Guidance with theme, décor, colors &amp; invitations</li>
            <li>Assist with wedding attire &amp; party gifts</li>
            <li>Assist with travel &amp; accommodations for guests</li>
            <li>Assist with review of all vendor contracts</li>
            <li>Creation of wedding timeline</li>
            <li>Manage all vendor details</li>
            <li>Organize wedding party &amp; conduct rehearsal</li>
            <li>Assist wedding party with flowers/corsages</li>
            <li>Seating arrangement &amp; crowd control</li>
            <li>Set up personal items (signage, DIY décor, etc.)</li>
            <li>Audio/visual check</li>
            <li>Cue ceremony &amp; reception events</li>
            <li>Breakdown &amp; collection of personal items</li>
            <li>Distribute final vendor payments (provided by client)</li>
            <li>Unlimited phone &amp; email contact</li>
          </ul>
          <a href="#contact" class="btn btn-outline-gold package-cta">Inquire Now</a>
        </div>

      </div>

      <!-- Other Events -->
      <div class="other-events-band">
        <div class="other-events-content">
          <span class="eyebrow">Beyond Weddings</span>
          <h3>Event Planning &amp; Design</h3>
          <p>Birthdays, anniversaries, baby showers, brunch with the ladies? We do it ALL! No event is too big or too small — reach out and let's create something beautiful together.</p>
        </div>
        <a href="#contact" class="btn btn-gold">Get in Touch</a>
      </div>

    </div>
  </section>

  <!-- ===================== FAQ ===================== -->
  <section id="faq" class="section faq">
    <div class="container">
      <div class="faq-grid">
        <div class="faq-intro">
          <span class="eyebrow">FAQs</span>
          <span class="gold-line gold-line-left"></span>
          <h2>Frequently Asked<br />Questions</h2>
          <p>Have more questions? We'd love to connect.</p>
          <a href="#contact" class="btn btn-outline-gold" style="margin-top:1.5rem">Ask Us Anything</a>
        </div>
        <div class="faq-list">
          <details class="faq-item">
            <summary>What will working with a wedding planner entail?</summary>
            <div class="faq-answer">
              <p>Depending upon which package you choose, your wedding planner is there to organize and make sense of all the moving parts when planning a wedding. They will assist you with creating a budget, selecting vendors, creating a timeline for the day, and the overall seamless execution of your big day!</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Why do I need a day-of coordinator?</summary>
            <div class="faq-answer">
              <p>Weddings are expensive, but the one vendor that is crucial to making your big day a worry-free success is your coordinator! The day-of coordinator plays the integral role of managing your vendors, following a timeline for the day, and executing all the fine details to make your vision come alive.</p>
            </div>
          </details>
          <details class="faq-item">
            <summary>Do you offer custom packages if the three wedding options don't apply to me?</summary>
            <div class="faq-answer">
              <p>Absolutely! The three packages we offer may not suit your needs, or you may have specific events that span a few days. Whatever the case may be, we are more than happy to customize a package that suits your specific event needs.</p>
            </div>
          </details>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="gallery-strip" aria-label="Portfolio gallery">
    <div class="gallery-grid">
      <div class="gallery-item gallery-item-tall">
        <Image src={heroImg} alt="Styled shoot by Sprig & Ivy" loading="lazy" widths={[600, 900]} sizes="33vw" />
        <div class="gallery-overlay">
          <a href="#contact" class="btn btn-outline">Book This Look</a>
        </div>
      </div>
      <div class="gallery-item">
        <Image src={gallery2Img} alt="Wedding by Sprig & Ivy" loading="lazy" widths={[600, 900]} sizes="33vw" />
      </div>
      <div class="gallery-item">
        <Image src={gallery3Img} alt="80th birthday event by Sprig & Ivy" loading="lazy" widths={[600, 900]} sizes="33vw" />
      </div>
      <div class="gallery-item gallery-item-wide">
        <Image src={gallery4Img} alt="Wedding reception by Sprig & Ivy" loading="lazy" widths={[900, 1200]} sizes="66vw" />
        <div class="gallery-overlay">
          <a href="#contact" class="btn btn-outline">Plan Your Event</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TESTIMONIALS ===================== -->
  <section id="testimonials" class="section testimonials">
    <div class="testimonials-bg">
      <Image src={clientsBgImg} alt="" aria-hidden="true" loading="lazy" widths={[768, 1280, 1920]} sizes="100vw" />
      <div class="testimonials-overlay"></div>
    </div>
    <div class="container">
      <div class="section-header" style="color:white">
        <span class="eyebrow" style="color:var(--gold-light)">Client Love</span>
        <span class="gold-line"></span>
        <h2 style="color:white">What Our Clients Say</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <Image src={avatar05} alt="Randy M." loading="lazy" width={120} height={120} />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"They went above and beyond in working with my schedule. We did an old Hollywood theme and had my entire house and yard setup for her arrival. My wife had a good time. Thank you."</p>
          <div class="testimonial-author">
            <strong>Randy M.</strong>
            <span>Irvine, 2020 — 50th Birthday Party</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <Image src={avatar06} alt="Kimberly S." loading="lazy" width={120} height={120} />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"They walked me through every step. My favorite part was the wedding budget they helped me and my fiancé create and also cute DIY ideas that would help save more money. I would definitely recommend them."</p>
          <div class="testimonial-author">
            <strong>Kimberly S.</strong>
            <span>Lake Forest, 2021 — Wedding Planning</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <Image src={avatar07} alt="Amber S." loading="lazy" width={120} height={120} />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"AMAZING! I had a smaller wedding and other coordinators were charging in the thousands and it just seemed totally ridiculous. I came across Sprig &amp; Ivy and literally felt like these girls were my BFF!"</p>
          <div class="testimonial-author">
            <strong>Amber S.</strong>
            <span>San Diego, 2021 — Wedding Coordination</span>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-avatar">
            <Image src={avatar08} alt="Dhara P." loading="lazy" width={120} height={120} />
          </div>
          <div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>"I price shopped like crazy and no other coordinator offered the price they were able to give me. They were so willing to work with my budget and didn't force any additional services. I will work with them again."</p>
          <div class="testimonial-author">
            <strong>Dhara P.</strong>
            <span>Chino Hills, 2021 — Event Coordination</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CTA BAND ===================== -->
  <section class="cta-band section-sm">
    <div class="container">
      <div class="cta-band-inner">
        <div>
          <span class="eyebrow">Ready to Begin?</span>
          <h2>Let's Make Your Event Unforgettable</h2>
        </div>
        <a href="#contact" class="btn btn-gold">Start Planning</a>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT ===================== -->
  <section id="contact" class="section contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <span class="eyebrow">Get In Touch</span>
          <span class="gold-line gold-line-left"></span>
          <h2>Let's Chat About<br />Your Event</h2>
          <p>Whether you're just beginning to dream or ready to start planning, we'd love to connect. Fill out the form and we'll be in touch shortly!</p>
          <div class="contact-details">
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 5.27 5.27l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16.92z"/></svg>
              </div>
              <div>
                <span>Phone</span>
                <a href="tel:+17144559150">+1.714.455.9150</a>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <span>Email</span>
                <a href="mailto:contact@sprigandivy.com">contact@sprigandivy.com</a>
              </div>
            </div>
            <div class="contact-detail">
              <div class="contact-detail-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <span>Location</span>
                <p>Orange County, CA &amp; surrounding areas</p>
              </div>
            </div>
          </div>
          <div class="contact-social">
            <a href="https://www.instagram.com/sprigandivy" target="_blank" rel="noopener">@sprigandivy</a>
          </div>
        </div>

        <div class="contact-form-wrap">
          <form
            id="contact-form"
            action="https://submit-form.com/lDeONWre"
            method="POST"
            novalidate
          >
            <!-- Honeypot -->
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <!-- Redirect after submit -->
            <input type="hidden" name="_redirect" value="https://sprigandivy.com/?sent=1" />

            <div class="form-row">
              <div class="form-group">
                <label for="first_name">First Name <span aria-hidden="true">*</span></label>
                <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
              </div>
              <div class="form-group">
                <label for="last_name">Last Name <span aria-hidden="true">*</span></label>
                <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Email Address <span aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="event_type">Type of Event</label>
                <select id="event_type" name="event_type">
                  <option value="" disabled selected>Select event type</option>
                  <option>Wedding</option>
                  <option>Birthday Party</option>
                  <option>Baby Shower</option>
                  <option>Retirement Party</option>
                  <option>Corporate Event</option>
                  <option>Other</option>
                </select>
              </div>
              <div class="form-group">
                <label for="event_date">Date of Event</label>
                <input type="date" id="event_date" name="event_date" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="location">Location of Event</label>
                <input type="text" id="location" name="location" placeholder="City, Venue name..." />
              </div>
              <div class="form-group">
                <label for="guests">Number of Guests</label>
                <input type="number" id="guests" name="guests" min="1" placeholder="Estimated guest count" />
              </div>
            </div>
            <div class="form-group">
              <label for="message">Tell Us About Your Event</label>
              <textarea id="message" name="message" rows="5" placeholder="Share your vision, inspiration, budget range, or anything else you'd like us to know..."></textarea>
            </div>
            <button type="submit" class="btn btn-gold form-submit">Send My Inquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,
      rgba(0,0,0,0.5) 50%,
      rgba(0,0,0,0.6) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    padding: 0 2rem;
    max-width: 700px;
  }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    color: white;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  .hero-content p {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: rgba(255,255,255,0.6);
    animation: bounce 2s infinite;
    transition: color 0.2s;
  }

  .hero-scroll:hover { color: white; }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  /* ===== MARQUEE ===== */
  .marquee-strip {
    overflow: hidden;
    background: var(--cream);
    border-top: 1px solid var(--light-gray);
    border-bottom: 1px solid var(--light-gray);
    padding: 1.2rem 0;
  }

  .marquee-track {
    display: flex;
    gap: 2rem;
    white-space: nowrap;
    animation: marquee 30s linear infinite;
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gray);
    font-weight: 500;
  }

  .marquee-track .dot { color: var(--gold); }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== ABOUT ===== */
  .about { background: var(--white); }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-images {
    position: relative;
  }

  .about-img-main {
    position: relative;
    z-index: 2;
  }

  .about-img-main img {
    width: 100%;
    height: 580px;
    object-fit: cover;
